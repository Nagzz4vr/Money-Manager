<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- res/values/styles.xml -->
    <style name="CustomCalendar">
        <item name="android:weekDayTextAppearance">@android:style/TextAppearance.Small</item>
        <item name="android:dateTextAppearance">@android:style/TextAppearance.Medium</item>
        <item name="android:showWeekNumber">false</item>
        <item name="android:focusedMonthDateColor">#7F35FF</item>
        <item name="android:unfocusedMonthDateColor">#707070</item>
        <item name="android:selectedDateVerticalBar">@android:color/holo_purple</item>
    </style>
    <style name="WhiteDateText" parent="android:TextAppearance.DeviceDefault.Medium">
        <item name="android:textColor">#E6FFFFFF</item>
    </style>

    <style name="MutedWeekText" parent="android:TextAppearance.DeviceDefault.Small">
        <item name="android:textColor">#99FFFFFF</item>
    </style>
    <style name="Theme.MyApp.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@color/bg_surface</item>

        <item name="android:textColorPrimary">@color/text_90</item>
        <item name="android:textColorSecondary">@color/text_60</item>

        <item name="colorPrimary">@color/accent_primary</item>

        <item name="colorOnSurface">@color/text_90</item>

        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.MyApp.MediumComponent</item>
    </style>

    <style name="ShapeAppearance.MyApp.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>



</resources>
